# ==================== MONGODB ====================
# MongoDB Atlas URI (get from MongoDB Atlas → Database → Connect → Drivers → Node.js)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/leadbot_db?retryWrites=true&w=majority

# Database Name
DB_NAME=leadbot_db

# ==================== WEBHOOK ====================
# Your server URL (e.g., Render, Railway, Heroku, VPS)
# Must end with /webhook
WEBHOOK_URL=https://your-app-name.onrender.com/webhook

# ==================== SERVER ====================
# Port (Render/Heroku auto-sets this, local mein 3000)
PORT=3000
